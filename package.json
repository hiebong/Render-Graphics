{
  "name": "render-graphics",
  "version": "1.0.0",
  "description": "Render Graphics Digital Art Studio",
  "main": "index.js",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel deploy --prod",
    "lint": "eslint . --ext .js,.html",
    "stylelint": "stylelint \"**/*.{css,html}\" --customSyntax postcss-html",
    "htmlhint": "htmlhint public/**/*.html admin/**/*.html",
    "check-css-semicolon": "node scripts/check-css-semicolon.js",
    "check-js-syntax": "node scripts/check-js-syntax.js",
    "test": "npm run lint && npm run stylelint && npm run htmlhint && npm run check-css-semicolon && npm run check-js-syntax"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-plugin-html": "^8.1.4",
    "htmlhint": "^1.0.0",
    "postcss-html": "^1.8.1",
    "stylelint": "15.10.0",
    "stylelint-config-standard": "34.0.0"
  }
}

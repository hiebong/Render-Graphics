{
  "env": {
    "browser": true,
    "node": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "plugins": ["html"],
  "globals": {
    "closeLightbox": "readonly",
    "closeConfirmModal": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn"],
    "no-console": "off"
  }
}
